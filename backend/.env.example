# SMRT backend environment configuration.
# Copy this file to `.env` and fill in real values. Never commit the real .env.

# --- Database (SQLite only) ---
DATABASE_URL=sqlite:///./smrt.db

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_INACTIVITY_MINUTES=120

# --- Login lockout ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# --- Email verification & password reset ---
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=30
FRONTEND_BASE_URL=http://localhost:5173

# --- SMTP (optional — emails log to console when SMTP_HOST is empty) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@smrt.local

# --- Environment: development | production ---
# In production, email verification is required before login.
ENVIRONMENT=development

# --- CORS: comma-separated trusted frontend origins (no wildcards in production) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
