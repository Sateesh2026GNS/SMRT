# GNS Insights backend environment configuration.
# Copy this file to `.env` and fill in real values. Never commit the real .env.

# --- Database (SQLite only) ---
DATABASE_URL=sqlite:///./smrt.db

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_INACTIVITY_MINUTES=120

# --- Login lockout ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# --- Email verification & password reset ---
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=15
FORGOT_PASSWORD_RATE_LIMIT=5
FORGOT_PASSWORD_RATE_WINDOW_SECONDS=3600
FRONTEND_BASE_URL=http://localhost:5173

# --- SMTP (required for Forgot Password — success only after real delivery) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=info@gnssoftwares.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=info@gnssoftwares.com

# --- Environment: development | production ---
# In production, email verification is required before login.
ENVIRONMENT=development

# --- SaaS: public registration disabled; companies created by Super Admin ---
ALLOW_PUBLIC_REGISTRATION=false

# --- GNS Super Admin (single platform administrator) ---
SUPER_ADMIN_EMAIL=admin@gnssoftwares.com
SUPER_ADMIN_PASSWORD=Admin@gns2580
SUPER_ADMIN_MOBILE=9059186584

# --- SMS OTP (optional — OTP logged to console when empty) ---
SMS_API_KEY=

# --- CORS: comma-separated trusted frontend origins (no wildcards in production) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- AI Operator Assistant (OpenAI-compatible LLM) ---
# Leave LLM_API_KEY empty to use rule-based intent + real ERP data (no external API).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1
LLM_TIMEOUT_SECONDS=30
AI_ASSISTANT_ENABLED=true
