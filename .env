# SQLite database (default). File is created in backend/ on first start.
DATABASE_URL=sqlite:///./smrt.db

# --- Auth / JWT ---
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Environment: development | production ---
ENVIRONMENT=development

# --- SaaS: public registration disabled; companies created by Super Admin ---
ALLOW_PUBLIC_REGISTRATION=false

# --- GNS Super Admin (single platform administrator) ---
SUPER_ADMIN_EMAIL=admin@gnssoftwares.com
SUPER_ADMIN_PASSWORD=Admin@gns2580
SUPER_ADMIN_MOBILE=9059186584

# --- CORS: comma-separated list of allowed origins ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Password reset ---
PASSWORD_RESET_EXPIRE_MINUTES=15
FRONTEND_BASE_URL=http://localhost:5173

# --- SMTP (required for Forgot Password) ---
# Use a Gmail App Password (16 chars), NOT the normal email password.
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=info@gnssoftwares.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@gnssoftwares.com
